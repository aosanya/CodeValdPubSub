# CodeValdGit — environment configuration example.
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored and must never be committed.

# -------------------------------------------------------------------
# CodeValdCross integration
# -------------------------------------------------------------------

# gRPC address of the CodeValdCross orchestrator.
# When set, CodeValdGit calls Register on startup to announce itself.
# Leave unset to run CodeValdGit in standalone mode (no registration).
# CROSS_GRPC_ADDR=:50051

# How often CodeValdGit re-registers with CodeValdCross (heartbeat).
# Accepts Go duration strings (e.g. 30s, 1m). Set to 0 to disable.
# CROSS_PING_INTERVAL=30s

# Address that CodeValdCross will use to dial back into this service.
# Defaults to GIT_GRPC_LISTEN_ADDR. Override when the listen address is
# not directly reachable by CodeValdCross (e.g. in multi-host deployments).
# GIT_GRPC_ADVERTISE_ADDR=:50053

# Agency this CodeValdGit instance is scoped to.
# Included in every Register heartbeat sent to CodeValdCross so the
# registry can identify which agency each instance serves.
# Leave unset for instances that serve all agencies.
# CODEVALDGIT_AGENCY_ID=agency-123

# -------------------------------------------------------------------
# Inbound gRPC server
# -------------------------------------------------------------------

# TCP port the CodeValdGit gRPC server listens on.
# REQUIRED: This must be set. Use root .env for consistent port allocation.
# GIT_GRPC_LISTEN_ADDR takes precedence over CODEVALDGIT_PORT when set.
CODEVALDGIT_PORT=50053

# Full listen address for the inbound gRPC server (host:port).
# Defaults to ":${CODEVALDGIT_PORT}" when unset.
# GIT_GRPC_LISTEN_ADDR=:50053

# -------------------------------------------------------------------
# Filesystem backend
# -------------------------------------------------------------------

# Root directory for live agency repositories.
# Each agency is stored under: {GIT_REPOS_BASE_PATH}/{agencyID}/
# GIT_REPOS_BASE_PATH=/tmp/codevaldgit/repos

# Root directory for archived (soft-deleted) repositories.
# DeleteRepo moves repos here; PurgeRepo removes them permanently.
# GIT_REPOS_ARCHIVE_PATH=/tmp/codevaldgit/archive

# -------------------------------------------------------------------
# ArangoDB backend (MVP-GIT-008)
# Required only when using the ArangoDB backend instead of filesystem.
# -------------------------------------------------------------------

# ArangoDB server endpoint.
# GIT_ARANGO_ENDPOINT=http://localhost:8529

# Database name that holds the four Git collections
# (git_objects, git_refs, git_index, git_config).
# GIT_ARANGO_DATABASE=codevaldgit

# Database used exclusively by integration tests (make test-arango).
# A single persistent database is shared across all test runs; tests use
# unique agency IDs per run to avoid inter-test data pollution.
# GIT_ARANGO_DATABASE_TEST=codevald_tests

# ArangoDB credentials.
# GIT_ARANGO_USER=root
# GIT_ARANGO_PASSWORD=

# Local path for the billy.Filesystem working tree used by the ArangoDB backend.
# Leave empty (default) to use an in-memory worktree (memfs).
# GIT_ARANGO_WORKTREE_PATH=
