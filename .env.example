# CodeValdPubSub — environment configuration example.
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored and must never be committed.

# -------------------------------------------------------------------
# CodeValdCross integration
# -------------------------------------------------------------------

# gRPC address of the CodeValdCross orchestrator.
# When set, CodeValdPubSub calls Register on startup to announce itself.
# Leave unset to run CodeValdPubSub in standalone mode (no registration).
# CROSS_GRPC_ADDR=:50051

# How often CodeValdPubSub re-registers with CodeValdCross (heartbeat).
# Accepts Go duration strings (e.g. 30s, 1m). Set to 0 to disable.
# CROSS_PING_INTERVAL=30s

# Per-RPC timeout for each Register heartbeat call.
# CROSS_PING_TIMEOUT=5s

# Address that CodeValdCross will use to dial back into this service.
# Defaults to PUBSUB_GRPC_LISTEN_ADDR. Override when the listen address is
# not directly reachable by CodeValdCross (e.g. in multi-host deployments).
# PUBSUB_GRPC_ADVERTISE_ADDR=:50055

# Agency this CodeValdPubSub instance is scoped to.
# Included in every Register heartbeat sent to CodeValdCross so the
# registry can identify which agency each instance serves.
# Leave unset for instances that serve all agencies.
# PUBSUB_AGENCY_ID=agency-123

# -------------------------------------------------------------------
# Inbound gRPC server
# -------------------------------------------------------------------

# TCP port the CodeValdPubSub gRPC server listens on.
# REQUIRED: This must be set. Use root .env for consistent port allocation.
# PUBSUB_GRPC_LISTEN_ADDR takes precedence over PUBSUB_PORT when set.
PUBSUB_PORT=50055

# Full listen address for the inbound gRPC server (host:port).
# Defaults to ":${PUBSUB_PORT}" when unset.
# PUBSUB_GRPC_LISTEN_ADDR=:50055

# -------------------------------------------------------------------
# ArangoDB backend
# -------------------------------------------------------------------

# ArangoDB server endpoint.
# PUBSUB_ARANGO_ENDPOINT=http://localhost:8529

# Database name that holds the PubSub collections.
# PUBSUB_ARANGO_DATABASE=codevaldpubsub

# Database used exclusively by integration tests (make test-arango).
# A single persistent database is shared across all test runs; tests use
# unique agency IDs per run to avoid inter-test data pollution.
# PUBSUB_ARANGO_DATABASE_TEST=codevald_tests

# ArangoDB credentials.
# PUBSUB_ARANGO_USER=root
# PUBSUB_ARANGO_PASSWORD=
